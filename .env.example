# ==============================
# SERVER CONFIG
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# DATABASE
# ==============================
MONGODB_URI=mongodb://localhost:27017/finance_auditor

# ==============================
# AUTH
# ==============================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ==============================
# GOOGLE GEMINI AI
# ==============================
# Single key (basic)
GEMINI_API_KEY=your_gemini_api_key_here
# Multiple keys for rotation (comma-separated, optional — multiplies your quota)
# GEMINI_API_KEYS=key1,key2,key3
# Model to use (falls back through: gemini-2.5-flash → gemini-2.0-flash-lite → gemini-2.0-flash → gemini-1.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Minimum ms between API calls (prevents burst rate limits). Default: 1500
GEMINI_MIN_INTERVAL_MS=1500

# ==============================
# GOOGLE CLOUD VISION (OCR)
# ==============================
# Option 1: Service Account Key File (recommended)
GOOGLE_APPLICATION_CREDENTIALS=./config/google-credentials.json
# Option 2: API Key (simpler, use if available)
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ==============================
# FILE UPLOAD
# ==============================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ==============================
# POLICY ENGINE MICROSERVICE
# ==============================
POLICY_ENGINE_URL=http://localhost:8000

# ==============================
# SOCKET.IO / CORS
# ==============================
CLIENT_URL=http://localhost:5173

# ==============================
# EMAIL NOTIFICATIONS (Optional)
# ==============================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password

# ==============================
# EXCHANGE RATE API (Free tier)
# ==============================
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here
